{
    "name": "liturgia-iasd-desktop",
    "version": "1.0.0",
    "description": "Desktop wrapper for Liturgia IASD with multi-window projection support",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "npm run build && electron .",
        "dev": "concurrently -k \"npm run dev --prefix ../liturgia-iasd\" \"wait-on http://localhost:3000 && npm start\"",
        "pack": "npm run build && electron-forge package",
        "dist": "npm run build && electron-forge make"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
        "@types/node": "^25.2.2",
        "concurrently": "^9.2.1",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "typescript": "^5.3.3",
        "wait-on": "^9.0.3"
    },
    "dependencies": {
        "electron-store": "^8.1.0"
    }
}